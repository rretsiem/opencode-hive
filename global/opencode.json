{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "YOUR_FAST_MODEL",
  "default_agent": "orchestrator",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 24000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "*.pyc",
      "__pycache__/**",
      ".venv/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      "target/**",
      "*.lock",
      "*.min.js",
      "*.min.css"
    ]
  },
  "instructions": [
    ".opencode/rules/*.md",
    ".claude/rules/*.md"
  ]
}
